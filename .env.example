# ═══════════════════════════════════════════════════════════════
# Sage Backend — Environment Variables Template
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env — it contains secrets. (.env is in .gitignore)
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development                    # development | production | test

# ── Solana ────────────────────────────────────────────────────
SOLANA_NETWORK=devnet                   # devnet | mainnet-beta
SOLANA_RPC_URL=https://betsey-5efi0d-fast-devnet.helius-rpc.com
SEAL_PROGRAM_ID=EV3TKRVz7pTHpAqBTjP8jmwuvoRBRCpjmVSPHhcMnXqb
# Comma-separated extra program IDs allowed for Seal agents beyond core Solana programs.
# For mainnet live trading, include Meteora DLMM here (or pass allowedPrograms in the API request).
# SEAL_ALLOWED_PROGRAMS_MAINNET=LBUZKhRxPF3XUpBCjp4YzTKgLccjZhTSDM9YuVaPwxo
# SEAL_ALLOWED_PROGRAMS_DEVNET=

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=                             # ⚠️ REQUIRED — min 32 chars. Generate: openssl rand -base64 48
JWT_ISSUER=sage-backend
JWT_ACCESS_TTL=24h                      # Production recommended: 15m
JWT_REFRESH_TTL=30d                     # Production recommended: 7d

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/sage_dev   # Railway: auto-injected by PostgreSQL addon

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=*                          # Production: restrict to your app domain

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug                         # fatal | error | warn | info | debug | trace

# ── Meteora ───────────────────────────────────────────────────
METEORA_API_URL=https://dlmm-api.meteora.ag

# ── ML Service (optional) ────────────────────────────────────
# ML_SERVICE_URL=http://127.0.0.1:8100
# ML_API_KEY=

# ── Helius RPC (optional, recommended for production) ────────
# HELIUS_API_KEY=

# ── Sponsor (pays wallet creation rent + tx fees for users) ──
# Strategy 1 — Server-side keypair (recommended, zero deps)
# Generate: solana-keygen new --no-bip39-passphrase -o sponsor.json
# Extract:  node -e "const k=require('./sponsor.json');const bs58=require('bs58');console.log(bs58.encode(Buffer.from(k)))"
# Fund:     solana airdrop 2 <address> --url devnet
# SPONSOR_KEYPAIR=                      # base58-encoded 64-byte secret key

# Strategy 2 — Turnkey HSM (production upgrade path)
# TURNKEY_API_PUBLIC_KEY=
# TURNKEY_API_PRIVATE_KEY=
# TURNKEY_ORGANIZATION_ID=
# TURNKEY_WALLET_ADDRESS=               # Solana address of the Turnkey wallet

# ── Wallet (required for live trading only) ──────────────────
# WALLET_PATH=/path/to/keypair.json
# WALLET_PRIVATE_KEY=                   # OR: base64-encoded secret key
